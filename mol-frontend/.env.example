# REST API base URL used by axios (no trailing slash preferred)
# Local dev example:
VITE_API_BASE_URL=http://localhost:8080
# Cloudflare Pages production example:
# VITE_API_BASE_URL=https://api.your-domain.com

# WebSocket STOMP endpoint used by stomp client
# Local dev example:
VITE_WS_URL=ws://localhost:8080/ws/game
# Cloudflare Pages production example:
# VITE_WS_URL=wss://api.your-domain.com/ws/game
