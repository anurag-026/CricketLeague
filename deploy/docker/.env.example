# Copy to .env and fill before: docker compose -f deploy/docker/docker-compose.prod.yml up -d

POSTGRES_DB=mol
POSTGRES_USER=mol
POSTGRES_PASSWORD=change-me-strong-password

JWT_SECRET=change-me-minimum-32-character-secret-key!!

MOL_CORS_ALLOWED_ORIGINS=http://localhost

# Frontend build-time URLs (baked into image at build)
VITE_API_BASE_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080/ws/game

# Optional pre-built images
# MOL_BACKEND_IMAGE=ghcr.io/org/mol-backend:main-42
# MOL_FRONTEND_IMAGE=ghcr.io/org/mol-frontend:main-42
